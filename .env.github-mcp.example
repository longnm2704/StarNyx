# Copy this file to .env.github-mcp and replace the placeholder values.
# The real .env.github-mcp file is gitignored and should never be committed.
#
# Optional for GitHub Enterprise or custom GitHub domains.
# Example:
# export GITHUB_HOST="https://github-minhlong.com"
#
# Required: GitHub Personal Access Token (PAT) with the permissions
# needed for the GitHub MCP use cases in this repository.
export GITHUB_PERSONAL_ACCESS_TOKEN="REPLACE_WITH_YOUR_GITHUB_PAT"
